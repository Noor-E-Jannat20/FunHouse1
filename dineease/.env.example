# ---------------------------------------------------------------------------
# DineEase environment variables (root reference)
# Copy the relevant blocks into server/.env and client/.env — never commit .env
# ---------------------------------------------------------------------------

# ===== server/.env =====
NODE_ENV=development
PORT=5000

# MongoDB (local default). For Atlas use: mongodb+srv://<user>:<pass>@cluster/dineease
MONGO_URI=mongodb://127.0.0.1:27017/dineease

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Cookie / CORS
CLIENT_URL=http://localhost:5173

# Loyalty & billing config
LOYALTY_EARN_RATE=0.05      # points earned per 1 currency unit paid
LOYALTY_REDEEM_VALUE=1      # 1 point = this many currency units on redemption
VAT_RATE=0.05              # 5% VAT applied on invoices

# ===== client/.env =====
VITE_API_URL=http://localhost:5000/api
